# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ===========================================
# GEMINI API CONFIGURATION
# ===========================================

# Gemini API Key (required)
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Alternative environment variable names (for backward compatibility)
VITE_GOOGLE_API_KEY=your_gemini_api_key_here

# ===========================================
# USAGE EXAMPLE
# ===========================================
# 1. Copy this file: cp .env.example .env
# 2. Replace 'your_gemini_api_key_here' with your actual API key
# 3. Save the file
# 4. Restart your development server: npm run dev

# ===========================================
# ACTUAL .env FILE SHOULD LOOK LIKE:
# ===========================================
# VITE_GEMINI_API_KEY=AIzaSyC_your_actual_api_key_here
# VITE_GOOGLE_API_KEY=AIzaSyC_your_actual_api_key_here